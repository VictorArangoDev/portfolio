---
import "../style/header.css";
import Header from '../components/Header.astro';
import Favicon from '../../src/assets/logo.png';
import BlobAnimation from '../components/Background';
import '../style/header.css';
import 'aos/dist/aos.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={Favicon.src} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<style>
/* Preloader container */
.preloader-container {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  pointer-events: auto;
  z-index: 1000;
  color: black;
  opacity: 1;
}

/* Top section (57%) */
.top-section {
  position: absolute;
  height: 57%;
  z-index: 2;
  background-color: #000;
  display: flex;
  align-items: flex-end;
  left: 0;
  right: 0;
  top: 0;
  padding-left: 5rem;
  padding-right: 5rem;
  clip-path: polygon(0% 0%, 100% 0%, 100% 99.5755%, 0% 99.5755%);
}

/* Bottom section (44%) */
.bottom-section {
  position: absolute;
  height: 44%;
  background-color: #000;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 5rem;
  display: flex;
  align-items: flex-end;
  text-align: center;
  clip-path: polygon(0% 0.4245%, 100% 0.4245%, 100% 100%, 0% 100%);
}

/* Logo container */
.logo-container {
  text-align: center;
  width: 100%;
  position: relative;
  opacity: 1;
}

/* Logos wrapper */
.logos-wrapper {
  overflow: hidden;
  width: 100%;
  margin-bottom: 2.5rem;
}

.logos-inner {
  display: flex;
  justify-content: center;
  width: 100%;
}

/* Individual logos */
.logo-left,
.logo-center,
.logo-right {
  display: inline-flex;
  align-items: center;
}

.logo-center{
  position: relative;
  margin-right: 0.5rem;
}

/* Progress container */
.progress-container {
  display: flex;
  justify-content: center;
  position: relative;
  overflow: hidden;
  height: 0.15rem;
  opacity: 1;
}

.progress-track {
  width: 100%;
  height: 100%;
  background-color: rgba(205, 205, 205, 0.65);
}

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 100%;
  position: absolute;
  left: 0;
  top: 0;
  background-color: #fff;
  transform-origin: left;
  transform: scaleX(0);
}

/* Percentage container */
.percentage-container{
  overflow: hidden;
  width: 100%;
  opacity: 1;
}

/* Percentage text */
.percentage-text, #percentageText{
  font-size: 1.5rem;
  font-weight: 300;
  color: #fff;
}

.text-logo-preload {
  font-size: 4rem;
  color: white;
  font-family: 'Terra';
}
	</style>
	<body>
		<div
			id="preloader"
			class="preloader-container"
      style="background-color: #fff;"
		>

			<span id="topSection" class="top-section">
				<div id="logoContainer" class="logo-container">
					<div class="logos-wrapper">
						<div class="logos-inner">

							<div id="logoLeft" class="logo-left">
							  <span class="text-logo-preload">va</span>
							</div>


							<div id="logoCenter" class="logo-center">
								 <span class="text-logo-preload"> /</span>
							</div>


							<div id="logoRight" class="logo-right">
							  <span class="text-logo-preload">dev</span>
							</div>
						</div>
					</div>


					<div id="progressContainer" class="progress-container">
						<div class="progress-track"></div>
						<div id="progressBar" class="progress-bar"></div>
					</div>
				</div>
			</span>


			<span id="bottomSection" class="bottom-section">
				<div id="percentageContainer" class="percentage-container">
					<div>(<span id="percentageText">100%</span>)</div>
				</div>
			</span>
		</div>
		<BlobAnimation client:only/>
		<Header/>
		<main class="main main-viewport" id="main-viewport">
			<div class="sections-wrapper" id="sections-wrapper">
				<slot />
			</div>
		</main>
	</body>

	<!-- ── PRELOADER ──────────────────────────────────────────────────────────── -->
	<script>
		import { gsap } from "gsap/dist/gsap";
		import ScrollTrigger from "gsap/dist/ScrollTrigger";

		gsap.registerPlugin(ScrollTrigger);

		const container          = document.getElementById("preloader");
		const leftLogo           = document.getElementById("logoLeft");
		const rightLogo          = document.getElementById("logoRight");
		const centerLogo         = document.getElementById("logoCenter");
		const progressBar        = document.getElementById("progressBar");
		const percentageText     = document.getElementById("percentageText");
		const topSection         = document.getElementById("topSection");
		const bottomSection      = document.getElementById("bottomSection");
		const logoContainer      = document.getElementById("logoContainer");
		const progressContainer  = document.getElementById("progressContainer");
		const percentageContainer = document.getElementById("percentageContainer");

		const cfg = {
			show:   { duration: 0.8, ease: "power3.inOut" },
			reveal: { duration: 2,   ease: "expo.inOut"   },
			hide:   { duration: 0.5, ease: "expo.inOut"   },
		};

		function start() {
			gsap.to([logoContainer, progressContainer, percentageContainer], {
				opacity: 1, duration: cfg.show.duration, ease: cfg.show.ease, delay: 0.2
			});

			const prog = { value: 0 };
			gsap.to(prog, {
				value: 100, duration: 2, delay: 0.5, ease: "power2.out",
				onUpdate: () => {
					gsap.set(progressBar, { scaleX: prog.value / 100 });
					if (percentageText) percentageText.textContent = `${Math.round(prog.value)}%`;
				},
				onComplete: introAnimation,
			});
		}

		function introAnimation() {
			gsap.delayedCall(0.3, () => {
				const tl = gsap.timeline({ onComplete: () => gsap.delayedCall(0.5, exitAnimation) });
				tl.to(leftLogo,   { x: -500, duration: cfg.reveal.duration, ease: cfg.reveal.ease });
				tl.to(rightLogo,  { x:  500, duration: cfg.reveal.duration, ease: cfg.reveal.ease }, 0);
				tl.to(centerLogo, { opacity: 0, duration: cfg.reveal.duration * 0.5, ease: "power2.out" }, cfg.reveal.duration * 0.5);
			});
		}

		function exitAnimation() {
			const tl = gsap.timeline({
				onComplete: () => {
					gsap.set(container, { autoAlpha: 0 });
					(window as any).__preloaderDone = true;
					window.dispatchEvent(new Event("preloader:finish"));
				}
			});
			tl.to(topSection,    { clipPath: "polygon(0% 0%, 100% 0%, 100% 0%, 0% 0%)",             duration: cfg.hide.duration, ease: cfg.hide.ease });
			tl.to(bottomSection, { clipPath: "polygon(0% 100%, 100% 100%, 100% 100%, 0% 100%)",      duration: cfg.hide.duration, ease: cfg.hide.ease }, 0);
			tl.to(container,     { opacity: 0, duration: 0.5 });
		}

		start();
	</script>

	<!-- ── SCROLL SYSTEM ──────────────────────────────────────────────────────── -->
	<script>
	import { gsap } from "gsap";
	import { Observer } from "gsap/Observer";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(Observer, ScrollTrigger);

	const DESKTOP_MQ = "(min-width: 769px)";
	const REDUCE_MQ  = "(prefers-reduced-motion: reduce)";

	function initScrollSystem() {
		// ── Teardown instancia anterior ─────────────────────────────────────────
		const prev = (window as any).__scrollTeardown as (() => void) | undefined;
		if (prev) prev();

		const sections = gsap.utils.toArray<HTMLElement>(".section");
		if (!sections.length) return;

		let currentIndex = 0;
		let isAnimating  = false;

		// ── GSAP es la única fuente de verdad para visibilidad ──────────────────
		// Quitamos clase .active para que el CSS visibility:hidden no interfiera
		sections.forEach((s, i) => {
			s.classList.remove("active");
			gsap.set(s, i === 0
				? { autoAlpha: 1, yPercent: 0,   zIndex: 1 }
				: { autoAlpha: 0, yPercent: 100, zIndex: 0 }
			);
		});

		// ── Detección de breakpoint ─────────────────────────────────────────────
		const mqlDesktop = window.matchMedia(DESKTOP_MQ);
		const mqlReduce  = window.matchMedia(REDUCE_MQ);
		const isDesktop    = () => mqlDesktop.matches;
		const reduceMotion = () => mqlReduce.matches;

		// ── Transición vertical entre secciones ─────────────────────────────────
		const animateSection = (nextIndex: number, direction: number) => {
			if (isAnimating) return;
			if (nextIndex === currentIndex) return;
			if (nextIndex < 0 || nextIndex >= sections.length) return;

			isAnimating = true;

			const cur       = sections[currentIndex];
			const next      = sections[nextIndex];
			const dur       = reduceMotion() ? 0 : 1.0;
			const prevIndex = currentIndex;

			gsap.set(next, { yPercent: direction > 0 ? 100 : -100, autoAlpha: 0, zIndex: 2 });
			gsap.set(cur,  { zIndex: 1 });

			currentIndex = nextIndex;

			const tl = gsap.timeline({
				onStart: () => {
					window.dispatchEvent(new CustomEvent("section:leaving", { detail: { id: cur.id } }));
				},
				onComplete: () => {
					gsap.set(cur, { autoAlpha: 0, zIndex: 0 });
					isAnimating = false;
					window.dispatchEvent(new CustomEvent("section:entered", { detail: { id: next.id } }));
				},
				onInterrupt: () => {
					isAnimating  = false;
					currentIndex = prevIndex;
				},
			});

			tl.to(cur,  { yPercent: direction > 0 ? -100 : 100, autoAlpha: 0, duration: dur, ease: "power3.inOut" }, 0);
			tl.to(next, { yPercent: 0, autoAlpha: 1,             duration: dur, ease: "power3.inOut" }, 0);
		};

		// ── Navegar ─────────────────────────────────────────────────────────────
		const navigate = (direction: number) => {
			if (isAnimating) return;
			const current = sections[currentIndex];

			// Sección horizontal: delegar paneles a projects.astro
			if (current.dataset.type === "horizontal" && isDesktop()) {
				const goToPanel  = (window as any).__projectsGoToPanel   as ((i: number) => void) | undefined;
				const panelCount = (window as any).__projectsPanelCount  as number | undefined;
				const getCurrent = (window as any).__projectsCurrentPanel as (() => number) | undefined;
				if (goToPanel && panelCount !== undefined && getCurrent) {
					const ci = getCurrent();
					if (direction > 0 && ci < panelCount - 1) { goToPanel(ci + 1); return; }
					if (direction < 0 && ci > 0)              { goToPanel(ci - 1); return; }
				}
			}

			animateSection(currentIndex + direction, direction);
		};

		// ── Hash navigation ─────────────────────────────────────────────────────
		const findByHash = (hash: string) => {
			const id = hash.replace(/^#/, "");
			if (!id) return -1;
			return sections.findIndex((s) => s.id === id);
		};

		const goToHash = (hash: string) => {
			const idx = findByHash(hash);
			if (idx < 0) return;
			
			if (isDesktop() && !reduceMotion()) {
				if (idx === currentIndex) return;
				animateSection(idx, idx > currentIndex ? 1 : -1);
			} else {
				const section = sections[idx];
				if (section) section.scrollIntoView({ behavior: "smooth" });
			}
		};

		const onDocumentClick = (e: MouseEvent) => {
			const a = (e.target as HTMLElement)?.closest<HTMLAnchorElement>('a[href^="#"]');
			if (!a) return;
			const href = a.getAttribute("href") ?? "";
			if (href === "#" || href === "#!") {
				e.preventDefault();
				history.replaceState(null, "", "#home");
				goToHash("#home");
				return;
			}
			if (findByHash(href) >= 0) {
				e.preventDefault();
				history.replaceState(null, "", href);
				goToHash(href);
			}
		};
		document.addEventListener("click", onDocumentClick, true);

		// ── Observer — desktop + sin reduced-motion ─────────────────────────────
		Observer.getAll().forEach((o) => o.kill());
		let observer: ReturnType<typeof Observer.create> | null = null;

		if (isDesktop() && !reduceMotion()) {
			observer = Observer.create({
				type: "wheel,touch,pointer",
				wheelSpeed: -1,
				onUp:   () => navigate(1),
				onDown: () => navigate(-1),
				tolerance: 10,
				preventDefault: true,
			});
		} else {
			// Mobile / reduced-motion: scroll nativo, mostrar todo
			sections.forEach((s) => {
				gsap.set(s, { position: "relative", autoAlpha: 1, yPercent: 0, zIndex: "auto", visibility: "visible" });
			});
		}

		// ── Resize ─────────────────────────────────────────────────────────────
		let resizeTimer: ReturnType<typeof setTimeout>;
		const handleResize = () => {
			clearTimeout(resizeTimer);
			resizeTimer = setTimeout(() => {
				ScrollTrigger.refresh();
				const wasDesktop = !!observer;
				const nowDesktop = isDesktop() && !reduceMotion();
				if (wasDesktop !== nowDesktop) initScrollSystem();
			}, 200);
		};
		window.addEventListener("resize", handleResize);

		// ── Teardown ────────────────────────────────────────────────────────────
		const teardown = () => {
			observer?.kill();
			Observer.getAll().forEach((o) => o.kill());
			clearTimeout(resizeTimer);
			window.removeEventListener("resize", handleResize);
			document.removeEventListener("click", onDocumentClick, true);
			(window as any).__scrollTeardown = undefined;
		};
		(window as any).__scrollTeardown = teardown;

		// ── Hash inicial post-preloader ─────────────────────────────────────────
		const initialHash = window.location.hash;
		if (initialHash && findByHash(initialHash) >= 0) {
			const run = () => goToHash(initialHash);
			window.addEventListener("preloader:finish", run, { once: true });
			setTimeout(run, 100);
		}
	}

	document.addEventListener("DOMContentLoaded", initScrollSystem);
	document.addEventListener("astro:page-load",   initScrollSystem);
	</script>

</html>