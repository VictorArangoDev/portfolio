---
import "../style/header.css";
import video from "../assets/Prueba3.mp4";
---

<section class="section v-panel home__section v-panel active" id="home" data-type="vertical" data-id="v1">
  <div class="home_intro">
    <div class="container-medium">
      <div class="home_intro-grid">
        <div class="home_intro_content">
          <h1 class="home-title">Transforming<br />Digital Vision.</h1>
          <p class="home-description">
            I specialize in building high-performance FullStack applications that merge 
            clean architecture with exceptional user experiences. 
          </p>
          <p class="home-description">
            Focused on turning complex business challenges into seamless, scalable 
            digital realities through precision and purpose.
          </p>

          <a href="#contact" class="button button--stroke" data-block="button">
            <span class="button__flair"></span>
            <span class="button__label">Contact</span>
          </a>
        </div>
        <div class="home_intro_character">
          <div class="home_spline_roboto">
            <video autoplay muted loop playsinline class="videoAnimation">
              <source src={video} type="video/mp4" />
              <source src={video} type="video/webm" />
            </video>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-title,
  .home-description,
  .button--stroke,
  .videoAnimation {
    opacity: 0;
    will-change: transform, opacity;
  }

  @media (max-width: 850px) {
    .home__section {
      padding: 5rem 2rem 4rem !important;
    }
  }
</style>

<script>
  import { SplitText } from "gsap/SplitText";
  import { gsap } from "gsap";

  gsap.registerPlugin(SplitText);

  // ── SplitText setup ───────────────────────────────────────────────────────
  let split: InstanceType<typeof SplitText> | null = null;
  const mm = gsap.matchMedia();

  function setupSplit() {
    if (split) split.revert();
    split = new SplitText(".home-title", { type: "lines" });
  }

  // Pre-hide elements to prevent jump
  gsap.set([".home-title", ".home-description", ".button--stroke", ".videoAnimation"], { autoAlpha: 0 });

  function runIntroAnimations(delay = 0) {
    setupSplit();
    if (!split) return;

    mm.add(
      {
        isDesktop: "(min-width: 769px)",
        isMobile: "(max-width: 768px)",
        reduceMotion: "(prefers-reduced-motion: reduce)",
      },
      (context) => {
        const { reduceMotion } = context.conditions as { reduceMotion: boolean };

        if (reduceMotion) {
          gsap.set([".home-title", ".home-description", ".button--stroke", ".videoAnimation"], {
            autoAlpha: 1,
            clearProps: "all",
          });
          return;
        }

        const tl = gsap.timeline({ delay });

        // Title lines entrance
        tl.fromTo(split!.lines,
          { rotationX: -90, transformOrigin: "50% 50% -40px", autoAlpha: 0 },
          { rotationX: 0, autoAlpha: 1, duration: 0.8, ease: "power3.out", stagger: 0.1 },
          0
        );

        // Descriptions slide
        tl.fromTo(".home-description",
          { autoAlpha: 0, x: -20 },
          { autoAlpha: 1, x: 0, duration: 0.8, ease: "power2.out", stagger: 0.1 },
          0.3
        );

        // Character / Video reveal
        tl.fromTo(".videoAnimation",
          { autoAlpha: 0, scale: 0.9, clipPath: "inset(10% 10% 10% 10% round 20px)" },
          { autoAlpha: 1, scale: 1, clipPath: "inset(0% 0% 0% 0% round 0px)", duration: 1.4, ease: "expo.out" },
          0.1
        );

        // Contact button
        tl.fromTo(".button--stroke",
          { autoAlpha: 0, y: 15 },
          { autoAlpha: 1, y: 0, duration: 0.7, ease: "back.out(1.7)" },
          0.6
        );
      }
    );
  }

  window.addEventListener("resize", () => setupSplit());

  // ── Trigger after preloader finishes (or immediately if already done) ──────
  const PRELOADER_EVENT = "preloader:finish";

  if ((window as any).__preloaderDone) {
    runIntroAnimations(0.1);
  } else {
    window.addEventListener(
      PRELOADER_EVENT,
      () => {
        (window as any).__preloaderDone = true;
        runIntroAnimations(0.1);
      },
      { once: true }
    );
  }

  // ── Magnetic button ────────────────────────────────────────────────────────
  class MagneticButton {
    private DOM: { button: Element; flair: Element };
    private xSet: Function;
    private ySet: Function;

    constructor(buttonElement: Element) {
      this.DOM = {
        button: buttonElement,
        flair: buttonElement.querySelector(".button__flair") as Element,
      };
      this.xSet = gsap.quickSetter(this.DOM.flair, "xPercent");
      this.ySet = gsap.quickSetter(this.DOM.flair, "yPercent");
      this.bindEvents();
    }

    private getXY(e: MouseEvent) {
      const { left, top, width, height } = this.DOM.button.getBoundingClientRect();
      const xT = gsap.utils.pipe(
        gsap.utils.mapRange(0, width, 0, 100),
        gsap.utils.clamp(0, 100)
      );
      const yT = gsap.utils.pipe(
        gsap.utils.mapRange(0, height, 0, 100),
        gsap.utils.clamp(0, 100)
      );
      return { x: xT(e.clientX - left), y: yT(e.clientY - top) };
    }

    private bindEvents() {
      this.DOM.button.addEventListener("mouseenter", (e) => {
        const { x, y } = this.getXY(e as MouseEvent);
        this.xSet(x);
        this.ySet(y);
        gsap.to(this.DOM.flair, { scale: 1, duration: 0.4, ease: "power2.out" });
      });

      this.DOM.button.addEventListener("mouseleave", (e) => {
        const { x, y } = this.getXY(e as MouseEvent);
        gsap.killTweensOf(this.DOM.flair);
        gsap.to(this.DOM.flair, {
          xPercent: x > 90 ? x + 20 : x < 10 ? x - 20 : x,
          yPercent: y > 90 ? y + 20 : y < 10 ? y - 20 : y,
          scale: 0,
          duration: 0.3,
          ease: "power2.out",
        });
      });

      this.DOM.button.addEventListener("mousemove", (e) => {
        const { x, y } = this.getXY(e as MouseEvent);
        gsap.to(this.DOM.flair, { xPercent: x, yPercent: y, duration: 0.4, ease: "power2.out" });
      });
    }
  }

  document.querySelectorAll('[data-block="button"]').forEach((el) => new MagneticButton(el));
</script>