---
import Title from "./title.astro";

---
<section class="swipe-section section section-animation" id="projects" data-speed="1">
  <Title title="Projects" />
  <section class="panel light x-100">
    <h2 class="panel__number">2</h2>
  </section>
  <section class="panel x-100">
    <h2 class="panel__number">3</h2>
  </section>
  <section class="panel light x-100">
    <h2 class="panel__number">4</h2>
  </section>
  <section class="panel light x-100">
    <h2 class="panel__number">5</h2>
  </section>
  <section class="panel light x-100">
    <h2 class="panel__number">6</h2>
  </section>
  <section class="panel light x-100">
    <h2 class="panel__number">7</h2>
  </section>
</section>

<script>
  import { gsap } from "gsap";
  import ScrollTrigger from "gsap/dist/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const swipeSection = document.querySelector(".swipe-section");
  if (!swipeSection) throw new Error("No .swipe-section found");

  const swipePanels = gsap.utils.toArray<HTMLElement>(".swipe-section .panel");
  const OFFSCREEN_X = 120;

  let currentIndex = -1;
  let animating = false;

  gsap.set(swipePanels, {
    xPercent: OFFSCREEN_X,
    zIndex: (i: number) => swipePanels.length - i,
  });

  const intentObserver = ScrollTrigger.observe({
    target: swipeSection,
    type: "wheel,touch",
    wheelSpeed: -1,
    tolerance: 8,
    preventDefault: true,
    lockAxis: true,
    onUp: () => !animating && gotoPanel(currentIndex + 1, true),
    onDown: () => !animating && gotoPanel(currentIndex - 1, false),
  });

  intentObserver.disable();

  function gotoPanel(index: number, isScrollingDown: boolean) {
    animating = true;

    if (index === swipePanels.length && isScrollingDown) {
      animating = false;
      intentObserver.disable();
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = false;
      window.dispatchEvent(new Event("scrollToNextSection"));
      return;
    }
    if (index < 0 && !isScrollingDown) {
      animating = false;
      intentObserver.disable();
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = false;
      window.dispatchEvent(new Event("scrollToPrevSection"));
      return;
    }

    if (isScrollingDown) {
      gsap.to(swipePanels[index], {
        xPercent: 0,
        duration: 0.7,
        ease: "power2.out",
        onComplete: () => {
          animating = false;
        },
      });
    } else {
      gsap.to(swipePanels[currentIndex], {
        xPercent: OFFSCREEN_X,
        duration: 0.7,
        ease: "power2.in",
        onComplete: () => {
          animating = false;
        },
      });
    }

    currentIndex = index;
  }

  ScrollTrigger.create({
    trigger: ".swipe-section",
    start: "top top",
    end: "+=1",
    pin: true,
    anticipatePin: 1,
    onEnter: () => {
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = true;
      intentObserver.enable();
      gotoPanel(currentIndex + 1, true);
    },
    onEnterBack: () => {
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = true;
      intentObserver.enable();
      gotoPanel(swipePanels.length - 1, true);
    },
    onLeave: () => {
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = false;
    },
    onLeaveBack: () => {
      (window as typeof window & { __projectsSectionActive?: boolean }).__projectsSectionActive = false;
    },
  });
</script>
