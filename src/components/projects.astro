---
import Title from "./title.astro";

const projects = [
  {
    id: "01",
    title: "Luminary",
    category: "Brand Identity · Web",
    year: "2024",
    description: "A full-spectrum identity system for a luxury lighting studio. From logotype to digital presence.",
    tags: ["Branding", "Art Direction", "Webflow"],
    accent: "#C8A96E",
  },
  {
    id: "02",
    title: "Orbital",
    category: "Product · Motion",
    year: "2024",
    description: "Dashboard interface for a SaaS analytics platform. Data meets craft.",
    tags: ["UI/UX", "Design System", "React"],
    accent: "#7B9EA6",
  },
  {
    id: "03",
    title: "Sólido",
    category: "Editorial · Print",
    year: "2023",
    description: "Independent architecture magazine. Grid-breaking layouts and raw typographic expression.",
    tags: ["Editorial", "Typography", "Print"],
    accent: "#C47B5A",
  },
  {
    id: "04",
    title: "Kōdo",
    category: "Web App · Dev",
    year: "2023",
    description: "Developer tooling for real-time collaboration. Performance-first, no compromises.",
    tags: ["TypeScript", "Astro", "Puppeteer"],
    accent: "#8B7EC8",
  },
  {
    id: "05",
    title: "Mirlo",
    category: "Mobile · UX",
    year: "2023",
    description: "A mindfulness app that respects your attention. Intentional design at every layer.",
    tags: ["Mobile", "UX Research", "Figma"],
    accent: "#7DAF8C",
  },
  {
    id: "06",
    title: "Vanta",
    category: "3D · Interactive",
    year: "2022",
    description: "Generative 3D experience for a fashion house. Where code meets couture.",
    tags: ["Three.js", "GLSL", "WebGL"],
    accent: "#A67B9E",
  },
];
---

<section
  class="swipe-section section"
  id="projects"
  aria-label="Projects"
  role="region"
  data-panel-count={projects.length}
>
  <div class="projects-grid-bg" aria-hidden="true"></div>

  <!-- Meta -->
  <div class="projects-meta" aria-hidden="true">
    <span class="projects-meta__label">Selected Work</span>
    <span class="projects-meta__count js-count">— 01 / {String(projects.length).padStart(2,"0")}</span>
  </div>

  <!-- Dot nav -->
  <nav class="projects-nav" aria-label="Project navigation">
    {projects.map((_, i) => (
      <button
        class="projects-nav__dot"
        data-dot={i}
        aria-label={`Project ${i + 1}`}
        aria-current={i === 0 ? "true" : "false"}
      />
    ))}
  </nav>

  <!-- Progress -->
  <div class="projects-progress" aria-hidden="true">
    <div class="projects-progress__fill js-fill"></div>
  </div>

  <!-- Panels -->
  {projects.map((p, i) => (
    <article
      class={`panel${i === 0 ? " is-active" : ""}`}
      data-panel={i}
      style={`--accent:${p.accent}`}
      aria-hidden={i !== 0 ? "true" : "false"}
    >
      <div class="panel__info">
        <span class="panel__id">{p.id}</span>
        <span class="panel__cat">{p.category}</span>
        <h2 class="panel__title">{p.title}</h2>
        <p class="panel__desc">{p.description}</p>
        <ul class="panel__tags">
          {p.tags.map(t => <li>{t}</li>)}
        </ul>
        <div class="panel__foot">
          <button class="panel__cta">
            View Project
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
          </button>
          <span class="panel__year">{p.year}</span>
        </div>
      </div>

      <div class="panel__visual">
        <div class="panel__visual-glow"></div>
        <span class="panel__visual-num">{p.id}</span>
      </div>
    </article>
  ))}
</section>

<style>
/* ── Section ─────────────────────────────────────────────────────────────── */
.swipe-section {
  position: relative;
  width: 100%;
  height: 100vh;
  background: #080808;
  overflow: hidden;
}

/* ── Grid bg ─────────────────────────────────────────────────────────────── */
.projects-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
  background-size: 56px 56px;
  pointer-events: none;
}

/* ── Meta ────────────────────────────────────────────────────────────────── */
.projects-meta {
  position: absolute;
  top: 2rem;
  left: 2.5rem;
  display: flex;
  gap: .75rem;
  align-items: center;
  z-index: 10;
  pointer-events: none;
}
.projects-meta__label,
.projects-meta__count {
  font-family: 'DM Mono', monospace;
  font-size: .62rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.35);
}
.projects-meta__count { color: rgba(255,255,255,.55); }

/* ── Dots ────────────────────────────────────────────────────────────────── */
.projects-nav {
  position: absolute;
  bottom: 2.25rem;
  left: 50%;
  translate: -50% 0;
  display: flex;
  gap: .45rem;
  z-index: 10;
}
.projects-nav__dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,.18);
  cursor: pointer;
  padding: 0;
  transition: background .3s, scale .3s;
}
.projects-nav__dot[aria-current="true"] {
  background: #fff;
  scale: 1.5;
}

/* ── Progress ────────────────────────────────────────────────────────────── */
.projects-progress {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: rgba(255,255,255,.07);
  z-index: 10;
  overflow: hidden;
}
.projects-progress__fill {
  height: 100%;
  width: 100%;
  background: var(--accent, #fff);
  transform-origin: left;
  transform: scaleX(calc(1 / 6)); /* updated by JS */
  transition: transform .45s cubic-bezier(.4,0,.2,1),
              background .45s;
}

/* ── Panels ──────────────────────────────────────────────────────────────── */
.panel {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 2rem;
  padding: 6rem 2.5rem 4rem;
  /* all panels start hidden below */
  opacity: 0;
  transform: translateY(40px);
  pointer-events: none;
  transition:
    opacity .5s cubic-bezier(.4,0,.2,1),
    transform .5s cubic-bezier(.4,0,.2,1);
}
.panel.is-active {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.panel.is-exit-up {
  opacity: 0;
  transform: translateY(-40px);
}
.panel.is-exit-down {
  opacity: 0;
  transform: translateY(40px);
}
.panel.is-exit-left {
  opacity: 0;
  transform: translateX(-48px);
}
.panel.is-exit-right {
  opacity: 0;
  transform: translateX(48px);
}

/* ── Panel info ──────────────────────────────────────────────────────────── */
.panel__info {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.panel__id {
  font-family: 'DM Mono', monospace;
  font-size: .62rem;
  letter-spacing: .3em;
  color: var(--accent);
  text-transform: uppercase;
}
.panel__cat {
  font-family: 'DM Mono', monospace;
  font-size: .65rem;
  letter-spacing: .14em;
  color: rgba(255,255,255,.32);
  text-transform: uppercase;
}
.panel__title {
  font-family: 'Terra', Georgia, serif;
  font-size: clamp(2.8rem, 5.5vw, 5rem);
  font-weight: 300;
  letter-spacing: -.03em;
  line-height: .95;
  color: #fff;
  margin: 0;
}
.panel__desc {
  font-size: .88rem;
  line-height: 1.65;
  color: rgba(255,255,255,.45);
  max-width: 36ch;
  margin: 0;
}
.panel__tags {
  display: flex;
  flex-wrap: wrap;
  gap: .35rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
.panel__tags li {
  font-family: 'DM Mono', monospace;
  font-size: .58rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
  padding: .28rem .6rem;
  border-radius: 100px;
}
.panel__foot {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-top: .25rem;
}
.panel__cta {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  background: var(--accent);
  color: #080808;
  border: none;
  padding: .7rem 1.4rem;
  font-family: 'DM Mono', monospace;
  font-size: .65rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: 100px;
  transition: opacity .2s;
}
.panel__cta:hover { opacity: .82; }
.panel__year {
  font-family: 'DM Mono', monospace;
  font-size: .62rem;
  color: rgba(255,255,255,.22);
}

/* ── Panel visual ────────────────────────────────────────────────────────── */
.panel__visual {
  position: relative;
  height: 62vh;
  max-height: 580px;
  border-radius: 6px;
  background: color-mix(in srgb, var(--accent) 10%, #111);
  border: 1px solid color-mix(in srgb, var(--accent) 14%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.panel__visual-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse at 50% 60%,
    color-mix(in srgb, var(--accent) 22%, transparent),
    transparent 70%
  );
}
.panel__visual-num {
  font-family: 'DM Mono', monospace;
  font-size: clamp(7rem, 16vw, 14rem);
  font-weight: 900;
  color: color-mix(in srgb, var(--accent) 7%, transparent);
  line-height: 1;
  letter-spacing: -.04em;
  user-select: none;
  position: relative;
}

/* ── Mobile ──────────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .panel {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    padding: 5rem 1.25rem 4.5rem;
    gap: 1.25rem;
    align-items: start;
  }
  .panel__visual {
    height: 36vh;
    max-height: none;
    order: -1;
  }
  .panel__title {
    font-size: clamp(2rem, 9vw, 3rem);
  }
  .projects-meta { left: 1.25rem; }
}
</style>

<script>
  (() => {
    const section = document.querySelector<HTMLElement>(".swipe-section");
    if (!section) return;

    const panels   = Array.from(section.querySelectorAll<HTMLElement>(".panel"));
    const dots     = Array.from(section.querySelectorAll<HTMLButtonElement>("[data-dot]"));
    const fill     = section.querySelector<HTMLElement>(".js-fill");
    const countEl  = section.querySelector<HTMLElement>(".js-count");
    const TOTAL    = panels.length;

    let current = 0;
    let busy    = false;

    // ── UI sync ─────────────────────────────────────────────────────────────
    function syncUI(i: number) {
      if (countEl) {
        countEl.textContent = `— ${String(i + 1).padStart(2,"0")} / ${String(TOTAL).padStart(2,"0")}`;
      }
      if (fill) {
        const accent = getComputedStyle(panels[i]).getPropertyValue("--accent").trim();
        fill.style.background = accent;
        fill.style.transform  = `scaleX(${(i + 1) / TOTAL})`;
      }
      dots.forEach((d, idx) => d.setAttribute("aria-current", idx === i ? "true" : "false"));
      panels.forEach((p, idx) => p.setAttribute("aria-hidden", idx === i ? "false" : "true"));
    }

    // ── Transition ──────────────────────────────────────────────────────────
    // Desktop: panels slide vertically (up/down).
    // Mobile:  panels slide horizontally (left/right) — matches swipe direction.
    const IS_TOUCH = window.matchMedia("(pointer: coarse)").matches;

    function goTo(next: number, direction: "next" | "prev") {
      if (busy || next === current || next < 0 || next >= TOTAL) return;
      busy = true;

      const outgoing = panels[current];
      const incoming = panels[next];

      // Exit classes for CSS transition on outgoing panel
      if (IS_TOUCH) {
        outgoing.classList.remove("is-active");
        outgoing.classList.add(direction === "next" ? "is-exit-left" : "is-exit-right");
      } else {
        outgoing.classList.remove("is-active");
        outgoing.classList.add(direction === "next" ? "is-exit-up" : "is-exit-down");
      }

      // Set incoming panel's starting position (no transition yet)
      incoming.style.transition = "none";
      incoming.style.opacity    = "0";
      if (IS_TOUCH) {
        incoming.style.transform = direction === "next" ? "translateX(48px)" : "translateX(-48px)";
      } else {
        incoming.style.transform = direction === "next" ? "translateY(40px)" : "translateY(-40px)";
      }

      // Force reflow so browser registers the start state before animating
      incoming.getBoundingClientRect();

      // Animate in
      incoming.style.transition = "";
      incoming.classList.add("is-active");

      current = next;
      syncUI(current);

      setTimeout(() => {
        outgoing.classList.remove("is-exit-up", "is-exit-down", "is-exit-left", "is-exit-right");
        outgoing.style.opacity   = "";
        outgoing.style.transform = "";
        busy = false;
      }, 520);
    }

    // ── Public API — called by layout ───────────────────────────────────────
    function next(): boolean {
      if (current < TOTAL - 1) { goTo(current + 1, "next"); return true; }
      return false; // boundary — layout should advance to next section
    }

    function prev(): boolean {
      if (current > 0) { goTo(current - 1, "prev"); return true; }
      return false; // boundary — layout should go to prev section
    }

    function reset(fromEnd = false) {
      // Called when layout snaps INTO this section
      panels.forEach(p => {
        p.classList.remove("is-active", "is-exit-up", "is-exit-down");
        p.style.opacity   = "";
        p.style.transform = "";
        p.style.transition = "";
      });
      current = fromEnd ? TOTAL - 1 : 0;
      busy = false;
      panels[current].classList.add("is-active");
      syncUI(current);
    }

    // Expose to layout scroll controller
    (section as any)._carousel = { next, prev, reset };

    // ── Dot clicks ──────────────────────────────────────────────────────────
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        if (i === current) return;
        goTo(i, i > current ? "next" : "prev");
      });
    });

    // ── Keyboard (only when section is focused/active) ───────────────────────
    document.addEventListener("keydown", (e) => {
      if (!window.__projectsSectionActive) return;
      if (e.code === "ArrowDown" || e.code === "ArrowRight") {
        e.preventDefault();
        if (!next()) {
          section.dispatchEvent(new CustomEvent("carousel:boundary", { detail: { dir: "next" }, bubbles: true }));
        }
      } else if (e.code === "ArrowUp" || e.code === "ArrowLeft") {
        e.preventDefault();
        if (!prev()) {
          section.dispatchEvent(new CustomEvent("carousel:boundary", { detail: { dir: "prev" }, bubbles: true }));
        }
      }
    });

    // Init
    reset();
  })();
</script>