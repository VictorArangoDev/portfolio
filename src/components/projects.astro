    font-size: 0.6rem;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.02);
  }
  .panel__cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 1rem 2rem;
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 100px;
    width: fit-content;
    transition: all 0.4s ease;
    overflow: hidden;
    position: relative;
  }
  .panel__cta:hover {
    border-color: var(--accent);
    color: #000;
    background: var(--accent);
  }

  /* ── Panel visual ────────────────────────────────────────────────────────── */
  .panel__visual {
    position: relative;
    height: 70vh;
    max-height: 650px;
    border-radius: 12px;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.5);
  }
  .panel__visual-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(
      circle at 50% 50%,
      color-mix(in srgb, var(--accent) 15%, transparent),
      transparent 60%
    );
    filter: blur(40px);
  }
  .panel__visual-num {
    font-family: "DM Mono", monospace;
    font-size: clamp(8rem, 20vw, 18rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    letter-spacing: -0.05em;
    pointer-events: none;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 790px) {
    .projects-meta {
      left: 2rem;
      top: 2rem;
    }
   /* .projects-nav {
      translate: -50% 0;
      flex-direction: row;
      bottom: 2.5rem;
    }*/
    .h-panel {
      grid-template-columns: 1fr;
      padding: 5rem 2rem 4rem;
      gap: 1.5rem;
    }
    .panel__visual {
      height: 38vh;
      order: -1;
    }
    .panel__title {
      font-size: clamp(2.5rem, 11vw, 4rem);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(SplitText, Observer);

  const panels = gsap.utils.toArray<HTMLElement>(".h-panel");
  const dots = gsap.utils.toArray<HTMLButtonElement>(".projects-nav__dot");
  const countEl = document.querySelector<HTMLElement>(".js-count");
  const fillEl = document.querySelector<HTMLElement>(".js-fill");
  const gridBg = document.querySelector<HTMLElement>(".projects-grid-bg");
  const total = panels.length;

  let currentPanelIndex = 0;
  let isAnimating = false;
  let hasFirstAnimated = false;

  const splitTitles = panels.map(p => {
    const title = p.querySelector(".panel__title");
    return title ? new SplitText(title, { type: "chars" }) : null;
  });

  function updateUI(index: number) {
    const panel = panels[index];
    const accent = getComputedStyle(panel).getPropertyValue("--accent").trim();
    if (countEl) countEl.textContent = `— ${String(index + 1).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
    if (fillEl) {
      gsap.to(fillEl, {
        scaleX: (index + 1) / total,
        duration: 0.8,
        ease: "expo.out",
        backgroundColor: accent,
      });
    }
    dots.forEach((dot, i) => {
      dot.setAttribute("aria-current", i === index ? "true" : "false");
      if (i === index) dot.style.setProperty('--accent', accent);
    });
  }

  function animatePanel(inPanel: HTMLElement, outPanel: HTMLElement | null, direction: number) {
    if (isAnimating) return;
    isAnimating = true;

    const tl = gsap.timeline({ onComplete: () => { isAnimating = false; } });
    const split = splitTitles[panels.indexOf(inPanel)];

    if (gridBg) {
      gsap.to(gridBg, { x: -direction * 40, duration: 2, ease: "power2.out" });
    }

    if (outPanel) {
      const outSplit = splitTitles[panels.indexOf(outPanel)];
      if (outSplit) {
        tl.to(outSplit.chars, { y: direction > 0 ? -40 : 40, autoAlpha: 0, stagger: 0.02, duration: 0.4, ease: "power2.in" }, 0);
      }
      tl.to(outPanel, { autoAlpha: 0, x: direction > 0 ? -100 : 100, filter: "blur(10px)", scale: 0.95, duration: 0.8, ease: "expo.inOut", onComplete: () => outPanel.classList.remove("is-active") }, 0);
    }

    tl.fromTo(inPanel,
      { autoAlpha: 0, x: direction > 0 ? 100 : -100, scale: 0.95, filter: "blur(10px)" },
      { autoAlpha: 1, x: 0, scale: 1, filter: "blur(0px)", duration: 1.2, ease: "expo.inOut", onStart: () => inPanel.classList.add("is-active") },
      "-=0.6"
    );

    if (split) {
      tl.fromTo(split.chars, { y: direction > 0 ? 60 : -60, autoAlpha: 0 }, { y: 0, autoAlpha: 1, stagger: 0.03, duration: 0.8, ease: "back.out(1.4)" }, "-=0.7");
    }

    const info = inPanel.querySelector(".panel__info")?.children;
    if (info) {
      tl.from(gsap.utils.toArray(info).filter(el => !el.classList.contains('panel__title')), { autoAlpha: 0, y: 20, stagger: 0.08, duration: 0.6, ease: "power2.out" }, "-=0.6");
    }
    const visual = inPanel.querySelector(".panel__visual");
    if (visual) tl.from(visual, { scale: 1.1, autoAlpha: 0, duration: 1.2, ease: "expo.out" }, "-=1");
  }

  function goToPanel(nextIndex: number) {
    if (nextIndex === currentPanelIndex || isAnimating) return;
    if (nextIndex < 0 || nextIndex >= total) return;
    const direction = nextIndex > currentPanelIndex ? 1 : -1;
    const outPanel = panels[currentPanelIndex];
    const inPanel = panels[nextIndex];
    currentPanelIndex = nextIndex;
    updateUI(nextIndex);
    animatePanel(inPanel, outPanel, direction);
  }

  const mm = gsap.matchMedia();
  mm.add({
    isDesktop: "(min-width: 769px)",
  }, (context) => {
    const { isDesktop } = context.conditions as { isDesktop: boolean };
    
    gsap.set(panels, { autoAlpha: 0, x: 0 });
    panels[0].classList.add("is-active");
    gsap.set(panels[0], { autoAlpha: 1 });
    updateUI(0);

    const onEnter = (e: any) => {
      if (e.detail.id === "work" && !hasFirstAnimated) {
        hasFirstAnimated = true;
        animatePanel(panels[0], null, 1);
      }
    };

    if (isDesktop) {
      window.addEventListener("section:entered", onEnter);
    } else {
      // Touch support for horizontal slider on mobile
      Observer.create({
        target: ".h-container",
        type: "touch,pointer",
        onLeft: () => goToPanel(currentPanelIndex + 1),
        onRight: () => goToPanel(currentPanelIndex - 1),
        tolerance: 40,
        preventDefault: false,
      });
    }

    dots.forEach((dot, i) => dot.addEventListener("click", () => goToPanel(i)));
    
    (window as any).__projectsGoToPanel = (i: number) => goToPanel(i);
    (window as any).__projectsPanelCount = total;
    (window as any).__projectsCurrentPanel = () => currentPanelIndex;

    return () => {
      window.removeEventListener("section:entered", onEnter);
      splitTitles.forEach(s => s?.revert());
    };
  });
</script>
