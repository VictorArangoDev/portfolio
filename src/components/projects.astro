---
import projects from "../data/projects.json";
---

<section class="section h-container" id="work" data-type="horizontal">
  <div class="projects-grid-bg"></div>

  <div class="projects-meta">
    <span class="projects-meta__label">Index</span>
    <span class="projects-meta__count js-count"
      >— 01 / {String(projects.length).padStart(2, "0")}</span
    >
  </div>

  <nav class="projects-nav" aria-label="Projects navigation">
    {
      projects.map((_, i) => (
        <button
          class="projects-nav__dot"
          aria-label={`Go to project ${i + 1}`}
          aria-current={i === 0 ? "true" : "false"}
        />
      ))
    }
  </nav>

  <div class="projects-progress">
    <div class="projects-progress__fill js-fill"></div>
  </div>

  {
    projects.map((project, index) => (
      <article
        class={`h-panel ${index === 0 ? "is-active" : ""}`}
        style={`--accent: ${project.accentColor};`}
      >
        <div class="panel__info">
          <span class="panel__id">{project.id}</span>
          <span class="panel__cat">
            {project.category} • {project.year}
          </span>
          <h2 class="panel__title">{project.title}
            
          </h2>
          <p class="panel__desc">{project.description}</p>

          <ul class="panel__tags">
            {project.tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>

          <div class="panel__foot">
            <a href={project.link} target="_blank" class="panel__cta">
              View Source
            </a>
          </div>
        </div>

        <div class="panel__visual">
          <div class="panel__visual-glow" />
          {project.visual.type === "number" ? (
            <span class="panel__visual-num">{project.visual.value}</span>
          ) : (
            <img src={project.visual.value} alt={project.id} class="panel__img" />
          )}
        </div>
      </article>
    ))
  }
</section>

<style>
  /* ── Section ─────────────────────────────────────────────────────────────── */
  .section.h-container {
    background: #060606;
    overflow: hidden;
  }

  /* ── Grid bg ───────────────────────────────────────────────────────────── */
  .projects-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: center center;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Meta ────────────────────────────────────────────────────────────────── */
  .projects-meta {
    position: absolute;
    top: 3rem;
    left: 4.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    z-index: 10;
    pointer-events: none;
  }
  .projects-meta__label {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
  }
  .projects-meta__count {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #fff;
  }

  /* ── Dots ────────────────────────────────────────────────────────────────── */
  .projects-nav {
    position: absolute;
    bottom: 8.5rem;
    right: 4.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    z-index: 10;
  }
  .projects-nav__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }
  .projects-nav__dot:after {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--accent, #fff);
    opacity: 0;
    scale: 0.5;
    transition: all 0.4s ease;
  }
  .projects-nav__dot[aria-current="true"] {
    background: var(--accent, #fff);
    border-color: var(--accent, #fff);
    scale: 1.25;
  }
  .projects-nav__dot[aria-current="true"]:after {
    opacity: 1;
    scale: 1.5;
  }

  /* ── Progress Bar ───────────────────────────────────────────────────────── */
  .projects-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
    z-index: 10;
  }
  .projects-progress__fill {
    height: 100%;
    width: 100%;
    background: var(--accent, #fff);
    transform-origin: left;
    filter: drop-shadow(0 0 8px var(--accent, #fff));
  }

  /* ── Panels ──────────────────────────────────────────────────────────────── */
  .h-panel {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
    gap: 5rem;
    padding: 2rem 10rem;
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.4s ease;
  }
  .h-panel.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Panel info ──────────────────────────────────────────────────────────── */
  .panel__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .panel__id {
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.5em;
    color: var(--accent);
    opacity: 0.8;
  }
  .panel__cat {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }
  .panel__title {
    font-family: "Terra", serif;
    font-size: clamp(3rem, 7vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
  }
  .panel__desc {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    max-width: 45ch;
    margin: 0.5rem 0;
  }
  .panel__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }
  .panel__tags li {
    font-family: "DM Mono", monospace;
    font-size: 0.6rem;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.35rem 0.8rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.02);
  }
  .panel__cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 1rem 2rem;
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 100px;
    width: fit-content;
    transition: all 0.4s ease;
    overflow: hidden;
    position: relative;
    text-decoration: none;
    z-index: 10;
  }
  .panel__cta:hover {
    border-color: var(--accent);
    color: #000;
    background: var(--accent);
  }

  /* ── Panel visual ────────────────────────────────────────────────────────── */
  .panel__visual {
    position: relative;
    height: 70vh;
    max-height: 650px;
    border-radius: 12px;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.5);
  }
  .panel__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .panel__visual-glow {
    position: absolute;
    inset: -20%;
    background: radial-gradient(
      circle at 50% 50%,
      color-mix(in srgb, var(--accent) 15%, transparent),
      transparent 60%
    );
    filter: blur(40px);
  }
  .panel__visual-num {
    font-family: "DM Mono", monospace;
    font-size: clamp(8rem, 20vw, 18rem);
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    letter-spacing: -0.05em;
    pointer-events: none;
  }

  /* ── Mobile ──────────────────────────────────────────────────────────────── */
  @media (max-width: 850px) {
    .projects-meta {
      left: 1.5rem;
      top: 1.5rem;
    }

    .projects-nav {
        left: 78%;
        bottom: 3rem;
        right: auto;
        transform: translateX(-50%);
        flex-direction: row;
        gap: 1rem;
    }
    }

    .projects-nav__dot {
      width: 10px;
      height: 10px;
    }

    .h-panel {
      grid-template-columns: 1fr;
      padding: 4.5rem 1.5rem 4.5rem;
      gap: 1.5rem;
      align-content: start;
    }

    .panel__visual {
      height: 35vh;
      min-height: 200px;
      order: -1;
      width: 100%;
    }

    .panel__title {
      font-size: clamp(2.2rem, 10vw, 3.5rem);
      font-weight: 800;
      line-height: 1.1;
    }

    .panel__desc {
      font-size: 0.9rem;
      max-width: 100%;
    }

    .projects-progress {
      height: 2px;
    }
  }
</style>


<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  import { Observer } from "gsap/Observer";

  gsap.registerPlugin(SplitText, Observer);

  // ── FIX #5: Usar requestAnimationFrame doble para garantizar hidratación ──
  // En Astro con View Transitions el script puede correr antes de que el DOM
  // esté pintado. El doble rAF asegura que el layout ya existe.
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      init();
    });
  });

  function init() {
    const panels = gsap.utils.toArray<HTMLElement>(".h-panel");
    const dots = gsap.utils.toArray<HTMLButtonElement>(".projects-nav__dot");
    const countEl = document.querySelector<HTMLElement>(".js-count");
    const fillEl = document.querySelector<HTMLElement>(".js-fill");
    const gridBg = document.querySelector<HTMLElement>(".projects-grid-bg");
    const total = panels.length;

    let currentPanelIndex = 0;
    let isAnimating = false;
    let hasFirstAnimated = false;

    // ── FIX #1 + #4: SplitText dentro de init(), después del doble rAF ──────
    // Se crean aquí (no en top-level) para garantizar que el DOM está listo.
    // La función recreateSplits() permite rehacerlos limpiamente al hacer revert.
    let splitTitles: (SplitText | null)[] = [];

    function recreateSplits() {
      // FIX #4: revert splits anteriores antes de recrear
      splitTitles.forEach((s) => s?.revert());
      splitTitles = panels.map((p) => {
        const title = p.querySelector<HTMLElement>(".panel__title");
        if (!title) return null;
        return new SplitText(title, { type: "chars" });
      });
    }

    recreateSplits();

    // ── Setup inicial ─────────────────────────────────────────────────────────
    gsap.set(panels, { autoAlpha: 0, x: 0 });
    panels[0].classList.add("is-active");
    gsap.set(panels[0], { autoAlpha: 1 });
    updateUI(0);

    // FIX #2: Solo ocultar chars de paneles NO activos.
    // El panel[0] se animará en la entrada, así que también lo ocultamos,
    // pero SOLO si esperamos el evento section:entered. Si no hay event system,
    // animamos inmediatamente como fallback.
    splitTitles.forEach((s, i) => {
      if (s) gsap.set(s.chars, { autoAlpha: 0, y: 60 });
    });

    dots.forEach((dot, i) => dot.addEventListener("click", () => goToPanel(i)));

    (window as any).__projectsGoToPanel = (i: number) => goToPanel(i);
    (window as any).__projectsPanelCount = total;
    (window as any).__projectsCurrentPanel = () => currentPanelIndex;

    // ── FIX #5: Fallback si section:entered ya se disparó (race condition) ───
    // Verificamos si la sección ya es visible con IntersectionObserver como
    // fallback además del evento personalizado.
    const sectionEl = document.querySelector<HTMLElement>("#work");

    const onEnterSection = (e: any) => {
      if (e.detail?.id === "work" && !hasFirstAnimated) {
        hasFirstAnimated = true;
        animatePanel(panels[0], null, 1);
      }
    };
    window.addEventListener("section:entered", onEnterSection);

    // Fallback: IntersectionObserver por si el evento nunca llega
    if (sectionEl) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !hasFirstAnimated) {
            hasFirstAnimated = true;
            animatePanel(panels[0], null, 1);
          }
        },
        { threshold: 0.3 },
      );
      io.observe(sectionEl);

      // Limpieza del observer también en cleanup
      (window as any).__projectsCleanup = () => {
        window.removeEventListener("section:entered", onEnterSection);
        io.disconnect();
        splitTitles.forEach((s) => s?.revert());
      };
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function updateUI(index: number) {
      const panel = panels[index];
      const accent = getComputedStyle(panel).getPropertyValue("--accent").trim();
      if (countEl)
        countEl.textContent = `— ${String(index + 1).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
      if (fillEl) {
        gsap.to(fillEl, {
          scaleX: (index + 1) / total,
          duration: 0.8,
          ease: "expo.out",
          backgroundColor: accent,
        });
      }
      dots.forEach((dot, i) => {
        dot.setAttribute("aria-current", i === index ? "true" : "false");
        if (i === index) dot.style.setProperty("--accent", accent);
      });
    }

    function animatePanel(
      inPanel: HTMLElement,
      outPanel: HTMLElement | null,
      direction: number,
    ) {
      if (isAnimating) return;
      isAnimating = true;

      const tl = gsap.timeline({
        onComplete: () => {
          isAnimating = false;
        },
      });

      const inIndex = panels.indexOf(inPanel);
      const split = splitTitles[inIndex];

      if (gridBg) {
        gsap.to(gridBg, {
          x: -direction * 40,
          duration: 2,
          ease: "power2.out",
        });
      }

      // ── FIX #3: Calcular offset de overlap dinámicamente ─────────────────
      // Si no hay outPanel (primer render), la animación de entrada empieza
      // en t=0 sin overlap negativo que pueda producir t<0.
      const hasOut = outPanel !== null;
      const overlapIn = hasOut ? "-=0.6" : "0";       // panel slide-in
      const overlapChars = hasOut ? "-=0.7" : "-=0.7"; // chars siempre relativo a slide-in
      const overlapInfo = hasOut ? "-=0.6" : "-=0.5";
      const overlapVisual = hasOut ? "-=1" : "-=0.9";

      if (hasOut) {
        const outIndex = panels.indexOf(outPanel!);
        const outSplit = splitTitles[outIndex];
        if (outSplit) {
          tl.to(
            outSplit.chars,
            {
              y: direction > 0 ? -40 : 40,
              autoAlpha: 0,
              stagger: 0.02,
              duration: 0.2,
              ease: "power2.in",
            },
            0,
          );
        }
        tl.to(
          outPanel!,
          {
            autoAlpha: 0,
            x: direction > 0 ? -100 : 100,
            filter: "blur(10px)",
            scale: 0.95,
            duration: 0.4,
            ease: "expo.inOut",
            onComplete: () => outPanel!.classList.remove("is-active"),
          },
          0,
        );
      }

      tl.fromTo(
        inPanel,
        {
          autoAlpha: 0,
          x: direction > 0 ? 100 : -100,
          scale: 0.95,
          filter: "blur(10px)",
        },
        {
          autoAlpha: 1,
          x: 0,
          scale: 1,
          filter: "blur(0px)",
          duration: 0.6,
          ease: "expo.inOut",
          onStart: () => inPanel.classList.add("is-active"),
        },
        overlapIn,
      );

      // FIX #1/#2: Asegurarse de que los chars están en estado inicial antes
      // de animarlos (por si el split fue recreado o el estado quedó corrupto)
      if (split) {
        gsap.set(split.chars, { autoAlpha: 0, y: direction > 0 ? 60 : -60 });
        tl.to(
          split.chars,
          {
            y: 0,
            autoAlpha: 1,
            stagger: 0.03,
            duration: 0.4,
            ease: "back.out(1.4)",
          },
          overlapChars,
        );
      }

      const infoChildren = inPanel.querySelector(".panel__info")?.children;
      if (infoChildren) {
        const infoEls = gsap.utils
          .toArray<Element>(infoChildren)
          .filter((el) => !el.classList.contains("panel__title"));
        tl.from(
          infoEls,
          {
            autoAlpha: 0,
            y: 20,
            stagger: 0.08,
            duration: 0.3,
            ease: "power2.out",
          },
          overlapInfo,
        );
      }

      const visual = inPanel.querySelector(".panel__visual");
      if (visual) {
        tl.from(
          visual,
          { scale: 1.1, autoAlpha: 0, duration: 0.6, ease: "expo.out" },
          overlapVisual,
        );
      }
    }

    function goToPanel(nextIndex: number) {
      if (nextIndex === currentPanelIndex || isAnimating) return;
      if (nextIndex < 0 || nextIndex >= total) return;
      const direction = nextIndex > currentPanelIndex ? 1 : -1;
      const outPanel = panels[currentPanelIndex];
      const inPanel = panels[nextIndex];
      currentPanelIndex = nextIndex;
      updateUI(nextIndex);
      animatePanel(inPanel, outPanel, direction);
    }

    // ── FIX #4: Recrear splits en resize para evitar chars duplicados ────────
    const mm = gsap.matchMedia();
    mm.add(
      {
        isDesktop: "(min-width: 851px)",
        isMobile: "(max-width: 850px)",
      },
      (context) => {
        const { isDesktop } = context.conditions as { isDesktop: boolean };

        // Recrear splits porque el tamaño de fuente cambió (clamp en title)
        recreateSplits();

        // Re-ocultar chars de paneles inactivos tras recrear
        splitTitles.forEach((s, i) => {
          if (s && i !== currentPanelIndex) {
            gsap.set(s.chars, { autoAlpha:0, y: 0 });
          }
        });

        if (!isDesktop) {
          const obs = Observer.create({
            target: ".h-container",
            type: "touch,pointer",
            onLeft: () => goToPanel(currentPanelIndex + 1),
            onRight: () => goToPanel(currentPanelIndex - 1),
            tolerance: 60,
            preventDefault: false,
            dragMinimum: 10,
          });
          // FIX #4: cleanup correcto del observer en mm
          return () => obs.kill();
        }
      },
    );
  }
</script>
