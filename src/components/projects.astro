<style>
  /* ── Section ─────────────────────────────────────────────────────────────── */
  .section.h-container {
    background: #060606;
    overflow: hidden;
  }

  /* ── Grid bg ───────────────────────────────────────────────────────────── */
  .projects-grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: center center;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Meta ────────────────────────────────────────────────────────────────── */
  .projects-meta {
    position: absolute;
    top: 3rem;
    left: 4.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    z-index: 10;
    pointer-events: none;
  }
  .projects-meta__label {
    font-family: "DM Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
  }
  .projects-meta__count {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: #fff;
  }

  /* ── Dots ────────────────────────────────────────────────────────────────── */
  .projects-nav {
    position: absolute;
    bottom: 3.5rem;
    right: 4.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    z-index: 10;
  }
  .projects-nav__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }
  .projects-nav__dot:after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--accent, #fff);
    opacity: 0;
    scale: 0.5;
    transition: all 0.4s ease;
  }
  .projects-nav__dot[aria-current="true"] {
    background: var(--accent, #fff);
    border-color: var(--accent, #fff);
    scale: 1.25;
  }
  .projects-nav__dot[aria-current="true"]:after {
    opacity: 1;
    scale: 1.5;
  }

  /* ── Progress Bar ───────────────────────────────────────────────────────── */
  .projects-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.05);
    z-index: 10;
  }
  .projects-progress__fill {
    height: 100%;
    width: 100%;
    background: var(--accent, #fff);
    transform-origin: left;
    filter: drop-shadow(0 0 8px var(--accent, #fff));
  }

  /* ── Panels ──────────────────────────────────────────────────────────────── */
  .h-panel {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
    gap: 5rem;
    padding: 2rem 10rem;
    opacity: 0;
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.4s ease;
  }
  .h-panel.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Panel info ──────────────────────────────────────────────────────────── */
  .panel__info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .panel__id {
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.5em;
    color: var(--accent);
    opacity: 0.8;
  }
  .panel__cat {
    font-family: "DM Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }
  .panel__title {
    font-family: "Terra", serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 300;
    letter-spacing: -0.04em;
